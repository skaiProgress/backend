PORT=8080
# Порт на хосте для docker compose (если 8080 занят — например локальным `go run ./cmd/api`)
BACKEND_HOST_PORT=8080
APP_ENV=development
# Локальный запуск (go run): Postgres из docker compose на хосте
DATABASE_URL=postgres://postgres:postgres@localhost:54329/aiqadam?sslmode=disable
# Внутри Docker Compose используйте host postgres:
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/aiqadam?sslmode=disable
AUTH_JWT_SECRET=change-me
AUTH_JWT_ISSUER=aiqadam-backend
AUTH_JWT_EXPIRY_HOURS=24
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
STORAGE_PATH=./storage
PUBLIC_API_URL=http://localhost:8080

# OpenAI для AI-аналитики. ОБЯЗАТЕЛЬНО заполнить на сервере, иначе AI не работает.
# docker compose пробрасывает .env в контейнер через env_file (см. docker-compose.yml).
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
